{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadInboundMail",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::YOUR_INBOUND_BUCKET/*"
    },
    {
      "Sid": "SendForwardedMail",
      "Effect": "Allow",
      "Action": "ses:SendEmail",
      "Resource": "arn:aws:ses:YOUR_REGION:YOUR_ACCOUNT_ID:identity/*"
    }
  ]
}
